// firestore.rules — BarInventory v2.0
// ══════════════════════════════════════════════════════════════════════════════
// CAMBIOS v2.0:
//   • Subcollección /conteoPorUsuario/{area} ahora permite que admins
//     escriban el campo _userLocks (para reabrir conteos individuales).
//     Los usuarios solo pueden escribir su propio userId como clave.
//
//   • Nueva subcollección /auditoriaStatusUsuarios/{userId}:
//     Almacena el estado de bloqueo por usuario (pendiente/completada).
//     Usuario: puede crear/actualizar el documento con su propio uid.
//     Admin:   puede actualizar cualquier documento (reapertura).
//
//   • /inventarioApp/{docId}: regla de update mejorada para permitir
//     que usuarios escriban auditoriaStatusPorUsuario y auditUserRegistry
//     (campos nuevos de v2.5 del estado) sin tocar el catálogo.
// ══════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // FUNCIONES HELPER
    // ══════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocRef() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userProfileExists() {
      return isAuthenticated() && exists(userDocRef());
    }

    function getUserRole() {
      return get(userDocRef()).data.role;
    }

    function isAdmin() {
      return userProfileExists() && getUserRole() == 'admin';
    }

    function isUser() {
      return userProfileExists() && getUserRole() in ['admin', 'user'];
    }

    function isModifyingField(fieldName) {
      return request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasAny([fieldName]);
    }

    // ══════════════════════════════════════════════════════════
    // REGLA 1 — USUARIOS
    // ══════════════════════════════════════════════════════════
    match /usuarios/{uid} {

      allow read: if isAuthenticated()
                  && (request.auth.uid == uid || isAdmin());

      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'user'
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.createdAt is number
                    && request.resource.data.lastLogin is number;

      allow update: if isAdmin()
                    || (isAuthenticated()
                        && request.auth.uid == uid
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['role', 'uid', 'email']));

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 2 — DOCUMENTO PRINCIPAL DE INVENTARIO
    // ══════════════════════════════════════════════════════════
    match /inventarioApp/{docId} {

      allow read: if isUser();
      allow create: if isAdmin();

      // Admin = acceso completo.
      // User = puede escribir campos de conteo/auditoría y los nuevos
      //        campos de estado por usuario (v2.5), pero NO puede
      //        modificar catálogo de productos, carrito ni tab activa.
      allow update: if isAdmin()
                    || (isUser()
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['products', 'cart', 'activeTab', 'selectedArea']));

      allow delete: if isAdmin();

      // ── SUBCOLECCIÓN: stockAreas ───────────────────────────
      match /stockAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── SUBCOLECCIÓN: conteoAreas ──────────────────────────
      match /conteoAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── SUBCOLECCIÓN: conteoPorUsuario ─────────────────────
      // Ahora también almacena _userLocks para bloqueo/reapertura.
      // Admin puede escribir cualquier campo (incluyendo _userLocks).
      // User puede escribir sus propios datos de conteo.
      match /conteoPorUsuario/{area} {
        allow read:  if isUser();
        allow write: if isUser();   // Admin y user pueden escribir
                                    // (admin necesita escribir _userLocks)
      }

      // ── SUBCOLECCIÓN: ordersChunks — solo admin escribe ────
      match /ordersChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isAdmin();
      }

      // ── SUBCOLECCIÓN: inventoriesChunks ───────────────────
      match /inventoriesChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── SUBCOLECCIÓN: auditoriaStatusUsuarios (v2.0) ──────
      // Almacena el estado de bloqueo por usuario:
      //   /auditoriaStatusUsuarios/{userId}: { almacen, barra1, barra2 }
      //   cada campo es 'pendiente' | 'completada'
      // Admin puede leer y escribir cualquier documento (reapertura).
      // User solo puede escribir el documento correspondiente a su propio userId.
      // NOTA: userId aquí es el ID anónimo del dispositivo (no Firebase UID).
      //       No se puede validar propiedad estrictamente. Regla permisiva.
      match /auditoriaStatusUsuarios/{userId} {
        allow read:  if isUser();
        allow write: if isUser();   // Confiamos en la lógica de la app
      }
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 3 — NOTIFICACIONES
    // ══════════════════════════════════════════════════════════
    match /notificaciones/{notifId} {
      allow read: if isUser();

      allow create: if isUser()
                    && request.resource.data.fecha is number
                    && request.resource.data.tipo is string
                    && request.resource.data.mensaje is string;

      allow update: if isAdmin()
                    || (isUser()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['leida']));

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 4 — AJUSTES DE PRODUCTO
    // ══════════════════════════════════════════════════════════
    match /ajustes/{ajusteId} {
      allow read: if isAdmin()
                  || (isUser()
                      && resource.data.usuarioId == request.auth.uid);

      allow create: if isUser()
                    && request.resource.data.estado == 'pendiente'
                    && request.resource.data.fecha is number
                    && request.resource.data.productoId is string
                    && request.resource.data.campo is string
                    && request.resource.data.valorNuevo is string;

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasOnly(['estado', 'procesadoPor', 'fechaProcesado']);

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 5 — REPORTES PUBLICADOS
    // ══════════════════════════════════════════════════════════
    match /reportesPublicados/{reporteId} {
      allow read: if isUser();

      allow create: if isAdmin()
                    && request.resource.data.timestamp is number
                    && request.resource.data.titulo is string
                    && request.resource.data.publicadoPor is string;

      allow update: if false;  // Reportes son inmutables

      allow delete: if isAdmin();
    }

  }
}
