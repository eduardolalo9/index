// ══════════════════════════════════════════════════════════════════════════════
// firestore.rules — BarInventory v2.1
// ══════════════════════════════════════════════════════════════════════════════
//
// CÓMO PUBLICAR (dos opciones):
//
//   OPCIÓN A — Firebase Console (más rápido):
//     1. Ve a https://console.firebase.google.com/
//     2. Selecciona tu proyecto "bar-inventario-1109e"
//     3. Firestore Database → pestaña "Reglas"
//     4. Borra todo el contenido y pega este archivo completo
//     5. Clic en "Publicar"
//
//   OPCIÓN B — Firebase CLI:
//     firebase deploy --only firestore:rules
//
// ──────────────────────────────────────────────────────────────────────────────
// ESTRUCTURA DE COLECCIONES:
//
//   /usuarios/{uid}                            → perfiles de usuario + rol
//   /inventarioApp/{docId}                     → doc principal (products, etc.)
//   /inventarioApp/{docId}/stockAreas/{area}   → conteo operativo
//   /inventarioApp/{docId}/conteoAreas/{area}  → auditoría atómica
//   /inventarioApp/{docId}/conteoPorUsuario/{area} → conteo multiusuario
//   /inventarioApp/{docId}/ordersChunks/{chunk}    → historial pedidos
//   /inventarioApp/{docId}/inventoriesChunks/{chunk} → historial inventarios
//   /notificaciones/{notifId}                  → notificaciones tiempo real
//   /ajustes/{ajusteId}                        → solicitudes de ajuste
//   /reportesPublicados/{reporteId}            → reportes inmutables
//
// ══════════════════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // FUNCIONES HELPER
    // ══════════════════════════════════════════════════════════

    /** Usuario autenticado */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Referencia al perfil del usuario */
    function userDocRef() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    /** El perfil existe en Firestore */
    function userProfileExists() {
      return isAuthenticated() && exists(userDocRef());
    }

    /** Obtiene el rol desde /usuarios/{uid}.role */
    function getUserRole() {
      return get(userDocRef()).data.role;
    }

    /**
     * isAdmin() — true si rol == 'admin'.
     * REQUIERE que exista /usuarios/{uid} con role == 'admin'.
     *
     * IMPORTANTE: Si el administrador recibe "permission-denied",
     * ve a Firebase Console → Firestore → Data → colección "usuarios"
     * → busca tu UID → campo "role" debe ser exactamente: admin
     */
    function isAdmin() {
      return userProfileExists() && getUserRole() == 'admin';
    }

    /**
     * isUser() — true si rol es 'admin' o 'user'.
     * Cualquier usuario registrado puede leer y hacer conteos.
     */
    function isUser() {
      return userProfileExists() && getUserRole() in ['admin', 'user'];
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 1 — PERFILES DE USUARIO
    // /usuarios/{uid}
    // ══════════════════════════════════════════════════════════
    match /usuarios/{uid} {

      // Leer el propio perfil; admin puede leer cualquiera
      allow read: if isAuthenticated()
                  && (request.auth.uid == uid || isAdmin());

      // Crear perfil en primer login (solo con role 'user')
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'user'
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.createdAt is number
                    && request.resource.data.lastLogin is number;

      // Actualizar: admin = todo; usuario = solo displayName y lastLogin
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && request.auth.uid == uid
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['role', 'uid', 'email']));

      // Solo admin elimina perfiles
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 2 — DOCUMENTO PRINCIPAL
    // /inventarioApp/{docId}
    // ══════════════════════════════════════════════════════════
    match /inventarioApp/{docId} {

      allow read: if isUser();

      // Solo admin crea el documento raíz
      allow create: if isAdmin();

      // Admin escribe todo.
      // Usuario puede escribir campos de conteo/auditoría pero
      // NO puede tocar el catálogo de productos ni el carrito.
      allow update: if isAdmin()
                    || (isUser()
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['products', 'cart', 'activeTab', 'selectedArea']));

      allow delete: if isAdmin();

      // ── stockAreas ─────────────────────────────────────────
      match /stockAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── conteoAreas ────────────────────────────────────────
      match /conteoAreas/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── conteoPorUsuario ───────────────────────────────────
      match /conteoPorUsuario/{area} {
        allow read:  if isUser();
        allow write: if isUser();
      }

      // ── ordersChunks — solo admin escribe ──────────────────
      match /ordersChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isAdmin();
      }

      // ── inventoriesChunks — ambos roles guardan inventario ─
      match /inventoriesChunks/{chunk} {
        allow read:  if isUser();
        allow write: if isUser();
      }
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 3 — NOTIFICACIONES
    // /notificaciones/{notifId}
    // ══════════════════════════════════════════════════════════
    match /notificaciones/{notifId} {
      allow read: if isUser();

      allow create: if isUser()
                    && request.resource.data.fecha is number
                    && request.resource.data.tipo is string
                    && request.resource.data.mensaje is string;

      // Solo se puede marcar como leída (campo 'leida')
      allow update: if isAdmin()
                    || (isUser()
                        && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['leida']));

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 4 — AJUSTES DE PRODUCTO
    // /ajustes/{ajusteId}
    // ══════════════════════════════════════════════════════════
    match /ajustes/{ajusteId} {
      allow read: if isAdmin()
                  || (isUser()
                      && resource.data.usuarioId == request.auth.uid);

      allow create: if isUser()
                    && request.resource.data.estado == 'pendiente'
                    && request.resource.data.fecha is number
                    && request.resource.data.productoId is string
                    && request.resource.data.campo is string
                    && request.resource.data.valorNuevo is string;

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasOnly(['estado', 'procesadoPor', 'fechaProcesado']);

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════
    // REGLA 5 — REPORTES PUBLICADOS
    // /reportesPublicados/{reporteId}
    // ══════════════════════════════════════════════════════════
    match /reportesPublicados/{reporteId} {
      allow read: if isUser();

      allow create: if isAdmin()
                    && request.resource.data.timestamp is number
                    && request.resource.data.titulo is string
                    && request.resource.data.publicadoPor is string;

      allow update: if false;  // Reportes son inmutables

      allow delete: if isAdmin();
    }

  }
}
